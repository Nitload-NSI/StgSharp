using StgSharp.Mathematics;
using StgSharp.Mathematics.Internal;
using System;
using System.Runtime.CompilerServices;

namespace StgSharp.Mathematics.Numeric
{
    public partial class MatrixParallelThread
    {

        private const int KernelStealCount = 64;

        internal unsafe void BufferCompute(
                             MatrixParallelTask* p
        )
        {
            // while () { }
            int size = p->ElementSize * 16;
            long count = Unsafe.As<int, long>(ref p->PrimCount);
            long offset = Unsafe.As<int, long>(ref p->PrimTileOffset) * size;
            ScalarPacket* scalar = p->Scalar;
            IntPtr computeHandle = _context[p->ComputeHandle];
            ((delegate* unmanaged[Cdecl]<void*, void*, void*, void*, long, void>)computeHandle)((void*)(p->Left + offset),
                                                                                                (void*)(p->Right + offset),
                                                                                                (void*)(p->Answer + offset),
                                                                                                scalar,
                                                                                                count);
        }

        [MethodImpl(MethodImplOptions.AggressiveInlining)]
        internal unsafe void SpecialBufferCompute(
                             MatrixParallelTask* p
        )
        {
            switch ((MatrixElementType)p->ElementSize)
            {
                case MatrixElementType.F64:
                    ComputeFmaPanelF64(p);
                    return;
                case MatrixElementType.F32:
                    ComputeFmaPanelF32(p);
                    break;
                default:
                    break;
            }
        }

    }
}
