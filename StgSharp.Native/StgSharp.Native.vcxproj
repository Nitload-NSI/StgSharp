    <ClInclude Include="sn-head\sn_intrinsic.std.h" />
    <ClInclude Include="sn-head\sn_intrinsic.h" />
    <ClInclude Include="sn-head\sn_intrinsic.matkernel.h" />
    <ClInclude Include="sn-head\sn_target.h" />
    <ClInclude Include="sn-head\StgSharpNative.h" />
    <ClInclude Include="sn-head\wgl.h" />
  </ItemGroup>
  <ItemGroup>
    <None Include="naming.md" />
    <None Include="SIMDID.x86.md" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets">
  </ImportGroup>
</Project>