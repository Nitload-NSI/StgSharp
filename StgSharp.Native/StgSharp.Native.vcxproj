  <!--  header files                                            -->
  <!-- ════════════════════════════════════════════════════════ -->
  <ItemGroup>
    <ClInclude Include="lib\glfw\glfw3.h" />
    <ClInclude Include="lib\glfw\glfw3native.h" />
    <ClInclude Include="lib\stbi\stb_image.h" />
    <ClInclude Include="sn-head\gl.h" />
