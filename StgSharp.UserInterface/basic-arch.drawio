        <mxCell id="25TvGm5YAioSoPTIv9tO-97" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;服务 Service&lt;/h1&gt;&lt;p&gt;VSS中重型的任务应当抽象为服务&lt;br&gt;&lt;/p&gt;&lt;p&gt;诸如HPC数学计算，连续的数控操作等都应当各自抽象为一个服务，&lt;br&gt;甚至集群计算中的计算节点也可以抽象为集群管理软件的服务实例&lt;br&gt;一个VSS程序可以有很多个Service。&lt;/p&gt;&lt;p&gt;一个良好的设计的VSS架构程序中，一个服务的失效可能导致程序功能出错，&lt;br&gt;但是不可以影响其他Service实例的工作。&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="70" y="850" width="520" height="240" as="geometry" />
        </mxCell>
      </root>
