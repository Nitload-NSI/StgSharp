        <mxCell id="25TvGm5YAioSoPTIv9tO-50" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;状态 State&lt;/h1&gt;&lt;p&gt;State是VSS架构的核心，用于同步多种不同的视图输入并仲裁其操作&lt;br&gt;&lt;/p&gt;&lt;p&gt;状态层通过状态宿主SH托管，SH应当为单例模式且程序生命周期内唯一，&lt;br&gt;具有多个SH的程序将变为分布式程序，不是VSS架构支持的目标。&lt;/p&gt;&lt;p&gt;整个程序的状态存放在程序状态集AS中，并进一步按照可视化界面和功能组&lt;br&gt;分为不同的局部状态PS，一个状态节点一般为一个属性，PS整体形成向量状态机&lt;/p&gt;&lt;p&gt;前端命令通过状态更新管线进行，状态更新管线使用源生成器自动化构建，不需要手写&lt;br&gt;执行管线会将执行结果返回到前端中。&lt;/p&gt;&lt;p&gt;复杂的，涉及到重型任务的操作将提交给后端命令调度器执行，后端命令调度器将根据&lt;br&gt;当前状态和命令要求，针对每一个Service录制一组指令流下发，并在执行过程中进行同步&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="60" y="475" width="520" height="240" as="geometry" />
        </mxCell>
        <mxCell id="25TvGm5YAioSoPTIv9tO-51" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;strokeColor=#000000;" parent="1" source="25TvGm5YAioSoPTIv9tO-7" target="25TvGm5YAioSoPTIv9tO-41" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="70" y="850" as="targetPoint" />
            <mxPoint x="60" y="590" as="sourcePoint" />
            <Array as="points">
              <mxPoint x="50" y="460" />
              <mxPoint x="50" y="650" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="25TvGm5YAioSoPTIv9tO-58" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.25;entryY=0;entryDx=0;entryDy=0;strokeColor=#66FF66;" parent="1" source="25TvGm5YAioSoPTIv9tO-53" target="25TvGm5YAioSoPTIv9tO-7" edge="1">
