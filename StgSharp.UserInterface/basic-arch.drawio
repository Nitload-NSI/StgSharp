        <mxCell id="25TvGm5YAioSoPTIv9tO-45" value="&lt;font style=&quot;font-size: 9px;&quot;&gt;状态更新观测器&lt;br&gt;UpdateObserver&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;" parent="1" vertex="1">
